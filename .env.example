# JWT secret for signing tokens (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Pastebin developer key (get from https://pastebin.com/doc_api#1)
PASTEBIN_DEV_KEY=your-pastebin-dev-key

# Database URL (optional, defaults to ./echovault.db)
DATABASE_URL=./echovault.db
